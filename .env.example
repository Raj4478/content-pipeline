# ── LLM — pick your provider ──────────────────────────────────────────
# Recommended order: gemini (free) → groq (nearly free) → deepseek (paid)
LLM_PROVIDER=gemini

# Gemini (primary — free tier, 15 req/min)
# Get key: aistudio.google.com → "Get API key"
# Valid models: gemini-2.5-flash-lite | gemini-2.5-flash | gemini-2.0-flash
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Groq (optional fallback — $0.05/1M tokens, very generous free tier)
# Get key: console.groq.com → "Create API key"
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# DeepSeek (optional — requires paid credits, skip if not using)
# Add credits at: platform.deepseek.com → Billing
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── ElevenLabs ────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Creatomate ────────────────────────────────────────────────────────
CREATOMATE_API_KEY=your_creatomate_key_here
CREATOMATE_TEMPLATE_ID=your_template_uuid_here

# ── Buffer ────────────────────────────────────────────────────────────
BUFFER_ACCESS_TOKEN=your_buffer_token_here
BUFFER_CHANNELS=channel_id_1,channel_id_2

# ── Pexels ────────────────────────────────────────────────────────────
PEXELS_API_KEY=your_pexels_key_here

# ── Cloudinary ────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── App ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
